{
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "framework": null,
  "rewrites": [
    { "source": "/api/tts", "destination": "/api/tts" },
    { "source": "/api/translate", "destination": "/api/translate" },
    { "source": "/api/suggest", "destination": "/api/suggest" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
